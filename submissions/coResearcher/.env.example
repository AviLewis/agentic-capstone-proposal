# coResearcher environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Required (backend fails fast if these are missing) ----------------------
# OpenAI API key used for all LLM reasoning.
OPENAI_API_KEY=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service role key (SERVER-SIDE ONLY, never expose to the client).
SUPABASE_SERVICE_KEY=

# Postgres connection URL for domain tables + LangGraph PostgresSaver.
# e.g. postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Optional ----------------------------------------------------------------
# Notion integration token for exporting approved plans via MCP.
NOTION_TOKEN=

# Notion page id (share the page with your integration) to create plan pages under.
NOTION_PARENT_PAGE_ID=

# Optional overrides for the Notion export (sensible defaults provided).
# NOTION_VERSION=2022-06-28
# NOTION_MCP_COMMAND=npx
# NOTION_MCP_ARGS=-y @notionhq/notion-mcp-server

# Contact email for the OpenAlex "polite pool" (recommended for reliability).
CONTACT_EMAIL=

# Optional Semantic Scholar API key for higher rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# --- App behavior (optional overrides) ---------------------------------------
OPENAI_MODEL=gpt-4o
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Frontend ----------------------------------------------------------------
# Base URL of the backend API, consumed by the Next.js app at build/runtime.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
